{
    "name": "sunnysideup/ecommerce",
    "type": "silverstripe-vendormodule",
    "description": "Silverstripe E-commerce Application",
    "keywords": [
        "Silverstripe-CMS",
        "CMS",
        "Silverstripe",
        "e-commerce",
        "ecommerce",
        "payment",
        "shop",
        "sales",
        "webshop",
        "cart",
        "sales",
        "products",
        "selling stuff",
        "online payment",
        "services"
    ],
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Nicolaas Francken",
            "email": "modules@sunnysideup.co.nz",
            "role": "lead developer"
        }
    ],
    "require": {
        "silverstripe/cms": "^4.0 || ^5.0",
        "bummzack/sortablefile": "^2.0",
        "pelago/emogrifier": "^8.0@stable",
        "silverstripe/lumberjack": "^2.0 || ^3.0",
        "symbiote/silverstripe-grouped-cms-menu": "^4.0@stable",
        "sunnysideup/google_address_field": "^5.0-dev",
        "sunnysideup/phone_field": "^5.0-dev",
        "sunnysideup/cms_edit_link_field": "^5.0-dev",
        "sunnysideup/permission_provider": "^5.0-dev",
        "sunnysideup/vardump": "^5.0-dev",
        "sunnysideup/model-admin-many-tabs": "^5.0-dev",
        "sunnysideup/email_address_database_field": "^5.0-dev",
        "sunnysideup/silverstripe-ajax-select-field": "^5.0-dev",
        "sunnysideup/yes-no-any-filter": "^5.0-dev",
        "sunnysideup/branded-login-screen": "^5.0-dev",
        "sunnysideup/one-time-code-authentication": "^5.0-dev"
    },
    "suggest": {
        "sunnysideup/flush": "Better, faster output for tasks",
        "silverstripe/geoip": "Native Silverstripe way to work out the customer country. Make sure this works on your server, before installing it - otherwise it is useless.",
        "symbiote/silverstripe-grouped-cms-menu": "HIGHLY RECOMMENDED! merge e-commerce cms menu items into one section."
    },
    "extra": {
        "expose": [
            "client"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Sunnysideup\\Ecommerce\\": "src/",
            "Sunnysideup\\Ecommerce\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/biwac-websolutions-ag/silverstripe-grouped-cms-menu.git"
        }
    ]
}